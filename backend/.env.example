# PORT — port the Express server listens on
PORT=3001

# DATABASE_PATH — path to the SQLite database file (default: ../audit.db relative to src/)
DATABASE_PATH=./audit.db

# STELLAR_NETWORK — testnet or mainnet
STELLAR_NETWORK=testnet

# SOROBAN_RPC_URL — Soroban RPC endpoint for smart contract interactions
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Server-side signing key (only used for read-only simulation; real txs are signed client-side)
SERVER_SECRET_KEY=S...

# CORS — restrict to your frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# CORS_PREFLIGHT_MAX_AGE — Access-Control-Max-Age for preflight responses in seconds (default: 24 hours)
CORS_PREFLIGHT_MAX_AGE=86400

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# HORIZON_URL — Horizon REST API endpoint for account and transaction queries
HORIZON_URL=https://horizon-testnet.stellar.org

# FRONTEND_ORIGIN — allowed CORS origin (your frontend URL)
FRONTEND_ORIGIN=http://localhost:5173

# RATE_LIMIT_WINDOW_MS — sliding window duration for rate limiting in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX — max requests per window for read endpoints
RATE_LIMIT_MAX=100

# RATE_LIMIT_WRITE_MAX — max requests per window for write/mutation endpoints
RATE_LIMIT_WRITE_MAX=10

# REQUEST_TIMEOUT_MS — per-request timeout in milliseconds; returns 503 if exceeded (default: 30s)
REQUEST_TIMEOUT_MS=30000

# KEEP_ALIVE_TIMEOUT_MS — HTTP keep-alive timeout on the server socket (default: 35s)
KEEP_ALIVE_TIMEOUT_MS=35000

# HEADERS_TIMEOUT_MS — max time to receive full request headers (default: 40s)
HEADERS_TIMEOUT_MS=40000

export type Transaction = {
  // ...existing transaction fields...
};

export async function getTransactionHistory(
  contractId: string,
  offset = 0,
  limit = 10
): Promise<{ data: Transaction[]; total: number }> {
  const url = `/api/history/${encodeURIComponent(contractId)}?offset=${offset}&limit=${limit}`;
  const res = await fetch(url, { credentials: 'same-origin' });
  if (!res.ok) {
    const text = await res.text();
    throw new Error(text || 'Failed to fetch transaction history');
  }
  // backend now returns { data, total }
  return res.json() as Promise<{ data: Transaction[]; total: number }>;
}

import React, { useEffect, useState } from 'react';
import { getTransactionHistory, Transaction } from '../api';

const LIMIT = 10;

type Props = {
  contractId: string;
};

export default function TransactionHistory({ contractId }: Props) {
  const [transactions, setTransactions] = useState<Transaction[]>([]);
  const [offset, setOffset] = useState(0);
  const [total, setTotal] = useState<number | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  // Reset offset and total when contractId changes
  useEffect(() => {
    setOffset(0);
    setTotal(null);
  }, [contractId]);

  useEffect(() => {
    let mounted = true;
    setLoading(true);
    setError(null);

    getTransactionHistory(contractId, offset, LIMIT)
      .then((res) => {
        if (!mounted) return;
        setTransactions(res.data || []);
        setTotal(typeof res.total === 'number' ? res.total : 0);
      })
      .catch((err) => {
        if (!mounted) return;
        setError(err.message || 'Failed to load transactions');
        setTransactions([]);
        setTotal(0);
      })
      .finally(() => {
        if (!mounted) return;
        setLoading(false);
      });

    return () => {
      mounted = false;
    };
  }, [contractId, offset]);

  const start = total === 0 ? 0 : (transactions.length === 0 ? Math.min(offset + 1, total ?? 0) : offset + 1);
  const end = total === 0 ? 0 : Math.min(offset + LIMIT, total ?? offset + transactions.length);

  const prevDisabled = offset === 0;
  const nextDisabled = total !== null ? offset + LIMIT >= total : transactions.length < LIMIT;

  return (
    <div>
      <div>
        <strong>
          Showing {start}–{end} of {total ?? '...'} transactions
        </strong>
      </div>

      {loading && <div>Loading...</div>}
      {error && <div style={{ color: 'red' }}>{error}</div>}

      <table>
        <thead>
          <tr>
            {/* ...columns... */}
          </tr>
        </thead>
        <tbody>
          {transactions.map((tx) => (
            <tr key={tx/* replace with unique tx id field */}>
              {/* ...render tx fields... */}
            </tr>
          ))}
        </tbody>
      </table>

      <div style={{ marginTop: 8 }}>
        <button onClick={() => setOffset(Math.max(0, offset - LIMIT))} disabled={prevDisabled}>
          Previous
        </button>
        <button onClick={() => setOffset(offset + LIMIT)} disabled={nextDisabled} style={{ marginLeft: 8 }}>
          Next
        </button>
      </div>
    </div>
  );
}
